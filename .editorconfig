root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.el]
indent_size = 2

[*.org]
indent_size = 2
tab_width = 8

[Makefile]
indent_style = tab

[*.{yaml,yml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.sh]
indent_size = 2
