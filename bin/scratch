#!/usr/bin/env sh
:; # -*- mode: emacs-lisp; lexical-binding: t -*-
:; # Polyglot wrapper: shell execs Emacs in batch with this file as the script.
:; # Lines starting with `:;' are no-ops in elisp (`:' is a self-evaluating
:; # keyword, `;' starts a comment) and ignorable in shell (`:' is a no-op,
:; # `;' is a statement separator). Real elisp begins below the shell preamble.
:; case "$EMACS" in *term*) EMACS=emacs ;; *) EMACS="${EMACS:-emacs}" ;; esac
:; [ "x$EMACS" = xemacs ] && { type emacs >/dev/null 2>&1 || err=1; }
:; [ "x$err" = x ] || { echo "Error: failed to run Emacs with command '$EMACS'" >&2; exit 1; }
:; exec "$EMACS" -q --no-site-file --batch --load "$0" -- "$@"
:; exit 1   # unreachable

;;; scratch -- CLI for the scratch Emacs framework.

;;; Bookkeeping ---------------------------------------------------------------

(defvar scratch-cli--script-path
  (or load-file-name (buffer-file-name))
  "Absolute path to this script file.")

(defvar scratch-cli--emacs-dir
  (file-name-as-directory
   (directory-file-name
    (file-name-directory
     (directory-file-name
      (file-name-directory scratch-cli--script-path)))))
  "Path to the scratch framework dir (the parent of bin/).")

(defvar scratch-cli--default-user-dir
  (file-name-as-directory (expand-file-name "~/.scratch.d"))
  "Default path for the user's overrides dir.")

(defun scratch-cli--print (fmt &rest args)
  (princ (apply #'format fmt args))
  (terpri))

(defun scratch-cli--die (fmt &rest args)
  (princ (apply #'format (concat "scratch: " fmt) args))
  (terpri)
  (kill-emacs 2))

;;; install -------------------------------------------------------------------

(defun scratch-cli--starter-config-org ()
  (concat
   "#+title: Scratch Emacs Configuration\n"
   "#+property: header-args:emacs-lisp :tangle config.el :results silent :comments link\n"
   "#+property: header-args :tangle no :results silent :eval no-export\n"
   "#+startup: inlineimages fold\n"
   "\n"
   "* Overview\n"
   "Scratch is a thin literate Emacs framework: chemacs-friendly profile +\n"
   "straight.el + use-package + a small module loader. This file tangles into\n"
   "two outputs:\n"
   "\n"
   "- ~packages.el~ -- loaded first; eager package installs + module declarations.\n"
   "- ~config.el~  -- loaded second; your customizations on top.\n"
   "\n"
   "Re-tangling happens on every Emacs start when this file is newer than its\n"
   "outputs. To force a re-tangle and pre-install everything, run ~scratch sync~\n"
   "from the shell. ~scratch sync --force-tangle~ re-tangles even when mtimes lie.\n"
   "\n"
   "Every installed package is pinned to a commit SHA in\n"
   "~straight/versions/default.el~ (tracked in git). Emacs thaws to those\n"
   "commits on startup, so daily use is reproducible. After adding a new\n"
   "package or intentionally upgrading one, run ~scratch freeze~ to refresh\n"
   "the lockfile, then commit it.\n"
   "\n"
   "* Module system\n"
   "Modules live under ~modules/<category>/<name>/~ in the framework dir\n"
   "(~~/.config/emacs-scratch/~) or under the same path in this user dir;\n"
   "user dir wins on a name collision. Each module has optional ~packages.el~\n"
   "(declarations / eager installs) and ~config.el~ (configuration).\n"
   "\n"
   "Modules are inert until you call ~(scratch! ...)~ -- *without that call you\n"
   "get a bare Emacs with the early-init perf knobs and nothing else.* Uncomment\n"
   "the example block under [[*Modules]] below to opt in.\n"
   "\n"
   "** Declaration syntax\n"
   "Each ~:category~ keyword is followed by zero or more module names. Pass\n"
   "flags as a list ~(name +flag1 +flag2)~. Example:\n"
   "\n"
   "#+begin_src emacs-lisp :tangle no\n"
   "(scratch! :editor     (evil +everywhere) leader\n"
   "          :completion vertico corfu\n"
   "          :emacs      (vc +forge +gutter)\n"
   "          :checkers   syntax\n"
   "          :lang       org markdown\n"
   "          :term       vterm\n"
   "          :os         macos\n"
   "          :ui         theme modeline fonts treemacs workspaces smooth-scroll hl-todo info-colors)\n"
   "#+end_src\n"
   "\n"
   "Note: list ~:editor (... leader)~ near the top of `scratch!'. Producer\n"
   "modules layer their leader bindings on top of leader's baselines via\n"
   "last-write-wins, so leader needs to load first for the cascade to work.\n"
   "\n"
   "** Built-in modules\n"
   "\n"
   "*** :editor evil -- vim emulation\n"
   "Loads ~evil-mode~ with sensible defaults (~C-u~ scroll, granular insert-mode\n"
   "undo, ~Y~ to end of line, etc), plus a stack of near-universal companions:\n"
   "\n"
   "- [[https://github.com/emacs-evil/evil-surround][evil-surround]]: ~ys~ / ~cs~ / ~ds~ to add / change / delete a pair.\n"
   "- [[https://github.com/juliapath/evil-numbers][evil-numbers]]: ~g=~ / ~g-~ to increment / decrement at point.\n"
   "- [[https://github.com/redguardtoo/evil-nerd-commenter][evil-nerd-commenter]]: ~gc~ comment operator (~gcc~ for current line).\n"
   "- [[https://github.com/redguardtoo/evil-matchit][evil-matchit]]: ~%~ jumps between language-aware matching pairs.\n"
   "- [[https://github.com/wcsmith/evil-args][evil-args]]: ~ia~ / ~aa~ as inner / outer text objects for function args\n"
   "  (e.g. ~cia~ change inside the argument under point).\n"
   "- [[https://github.com/abo-abo/avy][avy]] for window-wide jumps under the ~gs~ prefix:\n"
   "  ~gs s~ jump to 2 chars, ~gs SPC~ jump to timed input,\n"
   "  ~gs c~ / ~gs l~ / ~gs w~ / ~gs W~ char / line / word / word-start.\n"
   "\n"
   "| flag         | effect                                                              |\n"
   "|--------------+---------------------------------------------------------------------|\n"
   "| ~+everywhere~ | also load ~evil-collection~ (vim bindings in dired/magit/many more) |\n"
   "\n"
   "*** :completion vertico -- modern minibuffer completion\n"
   "Bundles [[https://github.com/minad/vertico][vertico]] (vertical UI), [[https://github.com/oantolin/orderless][orderless]] (match input fragments\n"
   "in any order), [[https://github.com/minad/marginalia][marginalia]] (rich annotations), [[https://github.com/minad/consult][consult]] (richer\n"
   "completing-read commands), and [[https://github.com/oantolin/embark][embark]] + embark-consult (context\n"
   "actions on candidates). When the leader is also enabled, surfaces\n"
   "consult commands under ~SPC s~ (search), ~SPC y~ (yank ring), and\n"
   "upgrades ~SPC b b~ / ~SPC f r~ to the consult-aware variants.\n"
   "Top-level shortcuts: ~SPC /~ -> `consult-ripgrep' (requires the\n"
   "[[https://github.com/BurntSushi/ripgrep][ripgrep]] binary on PATH); ~SPC a~ -> `embark-act' (also bound to\n"
   "~C-.~ globally; ~M-.~ runs `embark-dwim').\n"
   "\n"
   "*** :completion corfu -- in-buffer popup completion\n"
   "[[https://github.com/minad/corfu][corfu]] -- minimalist at-point completion popup. Auto-pops after 2 chars\n"
   "with a short delay. Bundles ~corfu-history~ (persisted candidate ranking),\n"
   "~corfu-popupinfo~ (hover docs), [[https://github.com/LuigiPiucco/nerd-icons-corfu][nerd-icons-corfu]] (icon glyphs in the\n"
   "margin), [[https://github.com/minad/cape][cape]] (file / dabbrev / elisp-block completion-at-point), and\n"
   "~corfu-terminal~ (overlay-based popup for TTY frames).\n"
   "\n"
   "*** :editor leader -- SPC leader key\n"
   "Doom / Spacemacs-style leader: ~SPC~ (normal/visual/motion) opens a\n"
   "transient menu of bindings, with [[https://github.com/justbur/emacs-which-key][which-key]] popping up the available\n"
   "prefixes after a short pause. Backed by [[https://github.com/noctuid/general.el][general.el]] -- use the\n"
   "~scratch-leader-def~ definer in your own config to add bindings, e.g.:\n"
   "\n"
   "#+begin_src emacs-lisp :tangle no\n"
   "(scratch-leader-def\n"
   "  \"p p\" '(project-switch-project :which-key \"switch project\"))\n"
   "#+end_src\n"
   "\n"
   "Override (set BEFORE ~scratch!~):\n"
   "- ~scratch-leader-key~                 -- default ~\"SPC\"~ (evil normal/visual/motion + non-evil global)\n"
   "- ~scratch-leader-non-normal-key~      -- default ~\"M-SPC\"~ (evil insert/emacs states)\n"
   "- ~scratch-localleader-key~            -- default ~\",\"~ (per-mode menu in normal/visual/motion)\n"
   "- ~scratch-localleader-non-normal-key~ -- default ~\"M-,\"~ (per-mode menu in insert/emacs states)\n"
   "\n"
   "Bundled bindings include ~SPC f f~ (find file), ~SPC b b~ (switch buffer),\n"
   "~SPC w h/j/k/l~ (windmove), ~SPC h f~ (describe function), ~SPC q q~\n"
   "(quit), ~SPC g g~ (magit-status, when ~:emacs vc~ is enabled), and a\n"
   "~SPC p~ project submenu backed by built-in ~project.el~, with a\n"
   "projectile-style search-path / discovery layer on top:\n"
   "\n"
   "- ~p p~ switch project (jumps straight to find-file, no transient)\n"
   "- ~p f~ find file in project, ~p b~ switch buffer, ~p s~ search regexp\n"
   "- ~p d~ dired at project root, ~p k~ kill buffers, ~p !~ shell command\n"
   "- ~p l~ pick from known projects (completing-read, no help buffer),\n"
   "  ~p D~ discover under search path,\n"
   "  ~p C~ forget projects whose dirs are gone, ~p A~ add a directory,\n"
   "  ~p F~ forget current project\n"
   "\n"
   "Override (set BEFORE ~scratch!~ or in your config.org):\n"
   "- ~scratch-projects-search-path~ -- list of dirs to scan for git repos\n"
   "  (e.g. ~'(\"~/code\" \"~/work\")~). Discovered on startup and via ~p D~.\n"
   "- ~scratch-projects-search-depth~ -- max subdir depth (default 2).\n"
   "\n"
   "*** :emacs vc -- version control\n"
   "Git-focused VC stack: built-in ~vc~ trimmed to Git only, magit (always),\n"
   "[[https://github.com/alphapapa/magit-todos][magit-todos]] (TODO/FIXME section in ~magit-status~), [[https://github.com/rmuslimov/browse-at-remote][browse-at-remote]],\n"
   "[[https://github.com/emacsmirror/git-timemachine][git-timemachine]], [[https://github.com/magit/git-modes][git-modes]] (gitconfig/gitignore/...), and ~smerge-mode~\n"
   "that auto-enables on conflict markers.\n"
   "\n"
   "| flag     | effect                                                                       |\n"
   "|----------+------------------------------------------------------------------------------|\n"
   "| ~+forge~  | install forge for GitHub/GitLab issues + PRs (needs token in ~~/.authinfo~) |\n"
   "| ~+gutter~ | live VCS hunk indicators in the fringe / margin via [[https://github.com/dgutov/diff-hl][diff-hl]]              |\n"
   "\n"
   "Default bindings:\n"
   "- ~C-x g~     -- ~magit-status~\n"
   "- ~C-x M-g~   -- ~magit-dispatch~\n"
   "- ~C-c M-g~   -- ~magit-file-dispatch~\n"
   "- ~C-c m {n,p,r,a,b,l,u,...}~ -- smerge actions (next/prev/resolve/keep-...)\n"
   "\n"
   "Leader bindings (under ~SPC g~): ~g g~ status, ~g d~ dispatch, ~g l~ log,\n"
   "~g L~ log-buffer-file, ~g b~ blame, ~g f~ file-dispatch, ~g r~ browse-at-remote,\n"
   "~g R~ copy remote URL, ~g t~ git-timemachine.\n"
   "\n"
   "With ~+gutter~ enabled, ~SPC g h~ opens a hunk submenu: ~h n~/~h p~ next/prev,\n"
   "~h s~ stage, ~h r~ revert, ~h S~ show, ~h R~/~h X~ set/reset reference rev.\n"
   "\n"
   "*** :checkers syntax -- live linting via flycheck\n"
   "[[https://www.flycheck.org][flycheck]] enabled globally (~global-flycheck-mode~). Indicators land in\n"
   "the right fringe so they don't fight ~+gutter~ on the left. The\n"
   "emacs-lisp checker is restricted to project-tracked buffers as a\n"
   "[[https://nvd.nist.gov/vuln/detail/CVE-2024-53920][CVE-2024-53920]] mitigation. [[https://github.com/Ladicle/flycheck-posframe][flycheck-posframe]] shows the error message\n"
   "in a child-frame near point (auto-no-op in TTY frames; suppressed during\n"
   "evil insert/replace state and while a corfu candidate is selected).\n"
   "When ~:completion vertico~ is also enabled, [[https://github.com/minad/consult-flycheck][consult-flycheck]] takes over\n"
   "~SPC c x~ so the error list shows in the consult picker (with preview /\n"
   "narrowing). No flags.\n"
   "\n"
   "Bindings (under ~SPC c~ -- code):\n"
   "- ~SPC c x~ -- list errors (consult picker if vertico is on)\n"
   "- ~SPC c X~ -- recheck buffer\n"
   "- ~SPC c n~ / ~SPC c p~ -- next / prev error\n"
   "- ~SPC c e~ -- explain error at point\n"
   "- ~SPC c v~ -- verify checker setup\n"
   "- ~SPC c s~ / ~SPC c d~ -- select / disable a checker\n"
   "- ~]e~ / ~[e~ -- next / prev error (evil normal/motion)\n"
   "\n"
"*** :os macos -- macOS-specific defaults\n"
   "Tweaks that only make sense on Darwin (no-op elsewhere):\n"
   "- Undecorated rounded-corner frame (no titlebar, traffic-light controls intact)\n"
   "- ~ns-use-proxy-icon nil~ + ~frame-title-format nil~ for a clean header\n"
   "- ~ns-pop-up-frames nil~ so Finder-opened files reuse the current frame\n"
   "- Cmd-= / Cmd-- / Cmd-0 bound to ~text-scale-increase~ / ~decrease~ / reset\n"
   "\n"
   "No flags.\n"
   "\n"
   "*** :term vterm -- libvterm-backed terminal\n"
   "[[https://github.com/akermu/emacs-libvterm][vterm]] with sensible defaults: 5000-line scrollback, kill buffer on\n"
   "exit, no \"process is running\" prompt, no horizontal scroll margin,\n"
   "evil-aware ~vterm-copy-mode~ (motion-state for browsing, back to\n"
   "insert when copy-mode toggles off). The popup variant lands at the\n"
   "bottom 25% as a side-window, focus selected so you can start typing.\n"
   "\n"
   "Build prereqs: ~cmake~, ~libtool~, ~libvterm~ (macOS:\n"
   "~brew install cmake libtool~; the libvterm dep is bundled). vterm\n"
   "compiles a C dynamic module on first load.\n"
   "\n"
   "Bindings:\n"
   "- ~SPC o t~ -- toggle vterm popup at project root\n"
   "- ~SPC o T~ -- open vterm in current window at project root\n"
   "- Prefix arg with either: kill / cd to ~default-directory~ instead\n"
   "- ~C-q~ inside vterm: send the next key literally to the shell\n"
   "\n"
   "No flags.\n"
   "\n"
   "*** :ui treemacs -- side-pane file/project tree\n"
   "[[https://github.com/Alexander-Miller/treemacs][treemacs]] with sensible defaults: git status overlay, nerd-icons (also\n"
   "applied to ~dired~ via ~treemacs-icons-dired~), evil bindings (when\n"
   "~:editor evil +everywhere~ is on), magit integration (when ~:emacs vc~\n"
   "is on), workspace scope (when ~:ui workspaces~ is on). No flags.\n"
   "\n"
   "Treemacs core is pure elisp -- no python required. Two opt-in\n"
   "features (extended/deferred git mode, directory collapsing) bundle a\n"
   "python helper. To opt in, set ~scratch-treemacs-git-mode~ to\n"
   "~'extended~ or ~'deferred~ before ~scratch!~. If ~python3~ isn't on\n"
   "PATH the module falls back to ~'simple~ silently.\n"
   "\n"
   "Bindings:\n"
   "- ~M-0~     -- focus / pop up the treemacs window (acts as \"window 0\")\n"
   "- ~SPC o p~ -- toggle project tree (treemacs)\n"
   "- ~SPC o P~ -- find current file in tree\n"
   "\n"
   "*** :ui workspaces -- isolated buffer sets via persp-mode\n"
   "[[https://github.com/Bad-ptr/persp-mode.el][persp-mode]]: named workspaces, each with its own buffer list and\n"
   "(optional) saved window configuration. A ~main~ workspace is created\n"
   "on startup; sessions can be saved to / loaded from ~persp-save-dir~\n"
   "(under ~user-emacs-directory~). doom-modeline shows the active\n"
   "workspace automatically; treemacs scopes to per-workspace state.\n"
   "No flags.\n"
   "\n"
   "Project integration (via built-in project.el): ~project-switch-project~\n"
   "(SPC p p) opens / switches to a workspace named after the project.\n"
   "Existing project workspaces are reused; an empty current workspace\n"
   "(e.g. fresh ~main~) is recycled rather than left as a stub.\n"
   "\n"
   "Leader bindings (under ~SPC l~):\n"
   "- ~SPC l l~   -- echo workspace tab bar\n"
   "- ~SPC l .~   -- switch workspace\n"
   "- ~SPC l n~   -- new workspace (auto-named ~#1~, ~#2~, ...)\n"
   "- ~SPC l N~   -- new workspace (named)\n"
   "- ~SPC l r~   -- rename current workspace\n"
   "- ~SPC l d~   -- kill current workspace\n"
   "- ~SPC l s~ / ~SPC l L~ -- save / load workspace from disk\n"
   "- ~SPC l ]~ / ~SPC l [~ -- next / prev workspace\n"
   "- ~SPC l 1~..~9~ / ~SPC l 0~ -- switch by index / final\n"
   "- ~SPC l TAB~ / ~SPC l \\``~ -- switch to last workspace\n"
   "- ~SPC l b~   -- workspace-restricted buffer switch\n"
   "- ~SPC ,~     -- workspace-restricted buffer switch (top-level)\n"
   "\n"
   "*** :ui smooth-scroll -- pixel-precise wheel scrolling\n"
   "[[https://github.com/jdtsmith/ultra-scroll][ultra-scroll]]: pixel-level smoothing for the mouse wheel and trackpad,\n"
   "based on Emacs 29's ~pixel-scroll-precision-mode~. Forces ~scroll-margin~\n"
   "to 0 (ultra-scroll requirement); ~scroll-conservatively~ is bumped to 3.\n"
   "\n"
   "| flag           | effect                                                              |\n"
   "|----------------+---------------------------------------------------------------------|\n"
   "| ~+interpolate~ | also smooth keyboard scrolls (C-v / M-v / evil C-d, C-u) via good-scroll |\n"
   "\n"
   "*** :ui hl-todo -- highlight TODO / FIXME / NOTE in comments\n"
   "[[https://github.com/tarsius/hl-todo][hl-todo]] in ~prog-mode~, ~yaml-mode~, and ~conf-mode~. Recognised\n"
   "keywords (case-sensitive, must end with the configured punctuation,\n"
   "default ~:~):\n"
   "\n"
   "| keyword     | use                                                          |\n"
   "|-------------+--------------------------------------------------------------|\n"
   "| ~TODO~       | reminder to change / add something later                     |\n"
   "| ~FIXME~      | broken / unimplemented / slow code that may bite later       |\n"
   "| ~REVIEW~     | code that needs a second look (upstreaming, polish, ...)     |\n"
   "| ~HACK~       | intentional code smell or future-fragile workaround          |\n"
   "| ~DEPRECATED~ | code on the way out                                          |\n"
   "| ~NOTE~       | non-actionable annotation                                    |\n"
   "| ~BUG~        | known defect (file an issue too)                             |\n"
   "| ~WARN~       | watch-out / careful-here                                     |\n"
   "| ~XXX~        | catch-all generic flag                                       |\n"
   "\n"
   "No flags. Customize keywords / faces by setting ~hl-todo-keyword-faces~\n"
   "after the module loads.\n"
   "\n"
   "When ~:completion vertico~ is also enabled, [[https://github.com/liuyinz/consult-todo][consult-todo]] is wired up:\n"
   "~SPC s t~ pickers TODOs in the current buffer, ~SPC s T~ across the\n"
   "current project (consult-style narrowing / preview).\n"
   "\n"
   "*** :ui info-colors -- colorized Info manual pages\n"
   "[[https://github.com/ubolonton/info-colors][info-colors]] highlights headings, references, and key chords in\n"
   "Info pages (~M-x info~ / ~C-h i~ / ~C-h r~ for the Emacs manual).\n"
   "Activates lazily on first Info node selection. No flags.\n"
   "\n"
   "*** :ui fonts -- comfortable default font sizing + mixed-pitch in prose\n"
   "Sets the default / fixed-pitch / variable-pitch face heights to 14pt\n"
   "(emacs' built-in default is small on HiDPI screens). Family is left at\n"
   "the system default unless overridden.\n"
   "\n"
   "Also installs [[https://gitlab.com/jabranham/mixed-pitch][mixed-pitch]] and auto-enables ~mixed-pitch-mode~ in\n"
   "prose modes (~org-mode~, ~markdown-mode~, ~gfm-mode~, ~Info-mode~ by\n"
   "default). Body text picks up your variable-pitch font; code blocks,\n"
   "tables, line numbers, syntax-highlighted regions, and Info's\n"
   "~`foo'~-style quotes stay fixed-pitch via\n"
   "~mixed-pitch-fixed-pitch-faces~. Heights stay consistent across the\n"
   "switch via ~mixed-pitch-set-height~.\n"
   "\n"
   "Override (set BEFORE ~scratch!~):\n"
   "- ~scratch-font-height~          (default 140, units are 1/10 pt)\n"
   "- ~scratch-font-family~          (default ~nil~ = system monospace)\n"
   "- ~scratch-font-variable-family~ (default ~nil~ = system variable-pitch)\n"
   "- ~scratch-mixed-pitch-modes~    (list of modes; ~nil~ disables mixed-pitch)\n"
   "\n"
   "*** :lang org -- pretty org-mode\n"
   "Sensible org-mode defaults plus [[https://github.com/minad/org-modern][org-modern]]: hidden emphasis markers,\n"
   "pretty entities, scaled monospace heading faces, ~visual-line-mode~,\n"
   "a slightly larger body-text size, and the modernized bullets / blocks /\n"
   "agenda from org-modern. [[https://github.com/awth13/org-appear][org-appear]] reveals the surrounding\n"
   "emphasis markers (~*bold*~ / ~/italic/~ / ~~code~~) when the cursor lands\n"
   "on the emphasized region, so editing doesn't feel blind.\n"
   "\n"
   "Companion packages: [[https://github.com/rexim/org-cliplink][org-cliplink]] (~M-x org-cliplink~ inserts a URL\n"
   "on the kill ring as an org link with the page title fetched live)\n"
   "and [[https://github.com/abo-abo/org-download][org-download]] (drag-and-drop / clipboard paste images directly\n"
   "into org buffers; default save dir is ~<org-directory>/images/~,\n"
   "override ~org-download-image-dir~ to relocate).\n"
   "\n"
   "Override (set BEFORE ~scratch!~):\n"
   "- ~scratch-org-font-scale~ -- default 1.15; multiplier applied to the\n"
   "  default face height in org buffers. Set to ~nil~ or ~1.0~ to disable.\n"
   "\n"
   "*** :lang markdown -- markdown-mode + sensible polish\n"
   "[[https://jblevins.org/projects/markdown-mode/][markdown-mode]] for ~.md~ / ~.markdown~ (with ~README.md~ landing in\n"
   "~gfm-mode~). Configures: native code-block syntax highlighting,\n"
   "asymmetric headers, italic underscore, ~visual-line-mode~, and a\n"
   "scaled / weight-tapered ~markdown-header-face-1~..~6~ palette.\n"
   "Pins ~markdown-table-face~ / ~markdown-pre-face~ / ~markdown-hr-face~\n"
   "to fixed-pitch so tables and HRs keep their alignment under\n"
   "~mixed-pitch-mode~. No flags.\n"
   "\n"
   "*** :ui modeline -- doom-modeline\n"
   "Polished, icon-rich modeline from [[https://github.com/seagle0128/doom-modeline][doom-modeline]] -- the same one Doom\n"
   "Emacs ships with. Shows buffer state, file path, major mode, vc branch,\n"
   "line:col, encoding, etc., with nerd-icons glyphs.\n"
   "\n"
   "Icons require nerd-fonts: run ~M-x nerd-icons-install-fonts~ once on a\n"
   "new machine. Icons auto-disable in TTY frames.\n"
   "\n"
   "No flags.\n"
   "\n"
   "*** :ui theme -- color theme\n"
   "Ships [[https://protesilaos.com/emacs/modus-themes][modus-themes]] (built-in to Emacs 28+; high contrast, pair well\n"
   "with doom-modeline). By default follows the OS appearance via\n"
   "~auto-dark~ (cross-platform: macOS / Linux / Windows / Termux).\n"
   "\n"
   "| flag             | effect                                       |\n"
   "|------------------+----------------------------------------------|\n"
   "| (none) / ~+auto~ | follow OS light/dark setting (the default)   |\n"
   "| ~+light~          | force light, no auto-switch                  |\n"
   "| ~+dark~           | force dark, no auto-switch                   |\n"
   "\n"
   "Override the actual theme symbols by ~setq~ on these vars BEFORE calling\n"
   "~scratch!~ (any module's ~defvar~ respects an existing binding):\n"
   "\n"
   "- ~scratch-theme-dark~  (default ~'modus-vivendi~)\n"
   "- ~scratch-theme-light~ (default ~'modus-operandi~)\n"
   "\n"
   "Example with [[https://github.com/doomemacs/themes][doom-themes]]:\n"
   "\n"
   "#+begin_src emacs-lisp :tangle no\n"
   "(straight-use-package 'doom-themes)\n"
   "(setq scratch-theme-dark  'doom-one\n"
   "      scratch-theme-light 'doom-one-light)\n"
   "(scratch! :ui theme)\n"
   "#+end_src\n"
   "\n"
   "** Predicates inside a module\n"
   "Within a module's ~config.el~ you can branch on its own flags or check\n"
   "whether a different module is enabled:\n"
   "\n"
   "#+begin_src emacs-lisp :tangle no\n"
   "(modulep! +flag)                  ; current module has +flag\n"
   "(modulep! :category name)         ; the named module is enabled\n"
   "(modulep! :category name +flag)   ; module enabled AND has +flag\n"
   "#+end_src\n"
   "\n"
   "* Packages\n"
   "Blocks tagged ~:tangle packages.el~ load /before/ ~config.el~. This is where\n"
   "module declarations live, plus any package that has to install eagerly\n"
   "(themes that need to load early, foundational libraries used in ~config.el~).\n"
   "\n"
   "With ~straight-use-package-by-default~ on, a plain ~(use-package foo)~ in\n"
   "~config.el~ already installs and configures in one step; reach for\n"
   "~packages.el~ for ~(straight-use-package 'foo)~ declarations or anything\n"
   "you need available before ~config.el~ runs.\n"
   "\n"
   "#+begin_src emacs-lisp :tangle packages.el\n"
   ";;; packages.el -*- lexical-binding: t; no-byte-compile: t; -*-\n"
   "#+end_src\n"
   "\n"
   "** Modules\n"
   "Uncomment to opt in. Add or remove modules and flags as you see fit; rerun\n"
   "~scratch sync~ after editing.\n"
   "\n"
   "#+begin_src emacs-lisp :tangle packages.el\n"
   ";; (scratch! :editor     (evil +everywhere) leader\n"
   ";;           :completion vertico corfu\n"
   ";;           :emacs      (vc +forge +gutter)\n"
   ";;           :checkers   syntax\n"
   ";;           :lang       org markdown\n"
   ";;           :term       vterm\n"
   ";;           :os         macos\n"
   ";;           :ui         theme modeline fonts treemacs workspaces smooth-scroll hl-todo info-colors)\n"
   "#+end_src\n"
   "\n"
   "** Extra packages\n"
   "Eager installs that aren't part of any module:\n"
   "\n"
   "#+begin_src emacs-lisp :tangle packages.el\n"
   ";; (straight-use-package 'some-package)\n"
   "#+end_src\n"
   "\n"
   "* Configuration\n"
   "Blocks here tangle to ~config.el~, which loads /after/ ~packages.el~ (and\n"
   "after every enabled module). Anything you set here is the last word.\n"
   "\n"
   "#+begin_src emacs-lisp\n"
   ";;; config.el -*- lexical-binding: t; -*-\n"
   "#+end_src\n"
   "\n"
   "** Identity\n"
   "#+begin_src emacs-lisp\n"
   ";; (setq user-full-name \"Your Name\"\n"
   ";;       user-mail-address \"you@example.com\")\n"
   "#+end_src\n"
   "\n"
   "** Better defaults\n"
   "#+begin_src emacs-lisp\n"
   ";; (setq-default indent-tabs-mode nil)\n"
   "#+end_src\n"
   "\n"
   "** use-package blocks\n"
   "Drop in ~(use-package ...)~ forms for personal packages and overrides.\n"
   "\n"
   "#+begin_src emacs-lisp\n"
   ";; (use-package which-key\n"
   ";;   :config (which-key-mode 1))\n"
   "#+end_src\n"))

(defun scratch-cli--starter-gitignore ()
  (concat
   "# Tangled output of config.org -- regenerated automatically.\n"
   "config.el\n"
   "packages.el\n"))

(defun scratch-cli--install-help ()
  (scratch-cli--print "Usage: scratch install [--user-dir DIR] [--force]")
  (scratch-cli--print "")
  (scratch-cli--print "Bootstrap the user config directory (default ~/.scratch.d).")
  (scratch-cli--print "Creates a starter config.org and .gitignore. By default, files")
  (scratch-cli--print "that already exist are left alone.")
  (scratch-cli--print "")
  (scratch-cli--print "Options:")
  (scratch-cli--print "  --user-dir DIR  Where to bootstrap. Defaults to $SCRATCHDIR or ~/.scratch.d.")
  (scratch-cli--print "  --force         Overwrite existing files."))

(defun scratch-cli-install (args)
  "Bootstrap the user config directory."
  (let ((user-dir (or (getenv "SCRATCHDIR")
                      scratch-cli--default-user-dir))
        (force nil))
    (while args
      (pcase (car args)
        ("--user-dir"
         (unless (cdr args)
           (scratch-cli--die "install: --user-dir requires a path"))
         (setq user-dir (cadr args) args (cddr args)))
        ((and arg (guard (and (stringp arg) (string-prefix-p "--user-dir=" arg))))
         (setq user-dir (substring arg (length "--user-dir="))
               args (cdr args)))
        ("--force" (setq force t args (cdr args)))
        ((or "-h" "--help")
         (scratch-cli--install-help)
         (kill-emacs 0))
        (arg (scratch-cli--die "install: unknown option: %s" arg))))
    (setq user-dir (file-name-as-directory (expand-file-name user-dir)))
    (make-directory user-dir t)
    (scratch-cli--print "Bootstrapping %s" user-dir)
    (scratch-cli--print "")
    (dolist (entry `((,(expand-file-name "config.org" user-dir)
                      . ,(scratch-cli--starter-config-org))
                     (,(expand-file-name ".gitignore"  user-dir)
                      . ,(scratch-cli--starter-gitignore))))
      (let ((path (car entry))
            (content (cdr entry)))
        (cond
         ((and (file-exists-p path) (not force))
          (scratch-cli--print "  exists  %s" path))
         (t
          (with-temp-file path (insert content))
          (scratch-cli--print "  %s  %s" (if force "force " "create") path)))))
    (scratch-cli--print "")
    (scratch-cli--print "Done. Edit %sconfig.org -- it'll tangle into config.el +" user-dir)
    (scratch-cli--print "packages.el on the next Emacs start.")
    (scratch-cli--print "Framework lives at: %s" scratch-cli--emacs-dir)))

;;; sync ----------------------------------------------------------------------

(defun scratch-cli--sync-help ()
  (scratch-cli--print "Usage: scratch sync [--force-tangle] [--rebuild]")
  (scratch-cli--print "")
  (scratch-cli--print "Re-tangle config.org and install all declared packages.")
  (scratch-cli--print "Run this after editing your literate config or adding modules.")
  (scratch-cli--print "")
  (scratch-cli--print "Options:")
  (scratch-cli--print "  --force-tangle  Re-tangle config.org even if outputs look fresh.")
  (scratch-cli--print "  --rebuild       Rebuild byte-compiled output of every installed package")
  (scratch-cli--print "                  (useful after upgrading Emacs)."))

(defun scratch-cli-sync (args)
  "Tangle the user config and install/build all declared packages."
  (let ((force-tangle nil)
        (rebuild nil))
    (while args
      (pcase (car args)
        ("--force-tangle" (setq force-tangle t args (cdr args)))
        ("--rebuild"      (setq rebuild t      args (cdr args)))
        ((or "-h" "--help") (scratch-cli--sync-help) (kill-emacs 0))
        (arg (scratch-cli--die "sync: unknown option: %s" arg))))

    ;; If chemacs/init normally sets `user-emacs-directory' to the framework
    ;; dir, mirror that here so straight installs into the right place.
    (setq user-emacs-directory scratch-cli--emacs-dir)

    ;; Force-tangle by removing the outputs so the framework's staleness check
    ;; trips. This works without us having to know whether `org' is loadable
    ;; before the framework's init runs.
    (when force-tangle
      (let* ((user-dir (file-name-as-directory
                        (expand-file-name (or (getenv "SCRATCHDIR")
                                              scratch-cli--default-user-dir))))
             (config   (expand-file-name "config.el"   user-dir))
             (packages (expand-file-name "packages.el" user-dir)))
        (when (file-exists-p config)
          (scratch-cli--print "Removing %s" config)
          (delete-file config))
        (when (file-exists-p packages)
          (scratch-cli--print "Removing %s" packages)
          (delete-file packages))))

    (scratch-cli--print "Loading framework...")
    (load (expand-file-name "init.el" scratch-cli--emacs-dir) nil 'nomessage)

    (when rebuild
      (scratch-cli--print "")
      (scratch-cli--print "Rebuilding all straight packages...")
      (when (fboundp 'straight-rebuild-all)
        (straight-rebuild-all)))

    (scratch-cli--print "")
    (scratch-cli--print "Sync complete.")))

;;; freeze --------------------------------------------------------------------

(defun scratch-cli--freeze-help ()
  (scratch-cli--print "Usage: scratch freeze")
  (scratch-cli--print "")
  (scratch-cli--print "Capture the current commit SHA of every installed package into")
  (scratch-cli--print "straight/versions/default.el (the lockfile, tracked in git).")
  (scratch-cli--print "")
  (scratch-cli--print "Run this after adding a new package or after intentionally")
  (scratch-cli--print "upgrading one. Subsequent `scratch sync' calls will pin to the")
  (scratch-cli--print "captured SHAs."))

(defun scratch-cli-freeze (args)
  "Write straight's versions lockfile."
  (while args
    (pcase (car args)
      ((or "-h" "--help") (scratch-cli--freeze-help) (kill-emacs 0))
      (arg (scratch-cli--die "freeze: unknown option: %s" arg))))
  (setq user-emacs-directory scratch-cli--emacs-dir)
  (scratch-cli--print "Loading framework...")
  (load (expand-file-name "init.el" scratch-cli--emacs-dir) nil 'nomessage)
  (unless (fboundp 'straight-freeze-versions)
    (scratch-cli--die "freeze: straight.el not loaded; run `scratch sync' first"))
  (scratch-cli--print "Writing straight/versions/default.el...")
  ;; Pass `force' to skip the interactive "push unsynced packages" step --
  ;; we want to record the LOCAL commit each repo is at, not push anything.
  (straight-freeze-versions t)
  (scratch-cli--print "Freeze complete."))

;;; Dispatch ------------------------------------------------------------------

(defun scratch-cli--usage ()
  (scratch-cli--print "scratch -- CLI for the scratch Emacs framework.")
  (scratch-cli--print "")
  (scratch-cli--print "Usage:")
  (scratch-cli--print "  scratch <command> [options]")
  (scratch-cli--print "")
  (scratch-cli--print "Commands:")
  (scratch-cli--print "  install [--user-dir DIR] [--force]   Bootstrap the user overrides dir")
  (scratch-cli--print "  sync [--force-tangle] [--rebuild]    Re-tangle and install all packages")
  (scratch-cli--print "  freeze                               Pin every installed package to its current commit")
  (scratch-cli--print "  help                                 Show this message")
  (scratch-cli--print "")
  (scratch-cli--print "Run `scratch <command> --help' for command-specific options."))

(let ((argv (cdr (member "--" command-line-args))))
  (pcase (car argv)
    ('nil           (scratch-cli--usage) (kill-emacs 2))
    ((or "help" "-h" "--help")
                    (scratch-cli--usage) (kill-emacs 0))
    ("install"      (scratch-cli-install (cdr argv)) (kill-emacs 0))
    ("sync"         (scratch-cli-sync    (cdr argv)) (kill-emacs 0))
    ("freeze"       (scratch-cli-freeze  (cdr argv)) (kill-emacs 0))
    (cmd
     (scratch-cli--print "scratch: unknown command: %s" cmd)
     (scratch-cli--print "")
     (scratch-cli--usage)
     (kill-emacs 2))))
