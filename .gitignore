# macOS noise
.DS_Store

# Generated package state. The canonical lockfile now lives in
# $SCRATCHDIR/versions/default.el; the framework copy is a cache.
straight/
eln-cache/
var/
.cache/
auto-save-list/
elpa/
transient/
server/
eshell/
places
semanticdb
tramp
network-security.data
smex-items
ede-projects.el

# Customize output (Emacs writes here at runtime)
custom.el

# Shell-env snapshot from `scratch env' -- machine-specific paths
env

# Bundled autoloads generated by `scratch sync' -- machine-specific
scratch-autoloads.el
scratch-autoloads.elc

# LSP state -- workspace cache and per-machine downloaded servers.
lsp-session
lsp-servers/

# Tree-sitter grammars compiled by `treesit-install-language-grammar'
# (or `treesit-auto-install-all'). Per-machine binaries; rebuild on
# clone with `M-x treesit-auto-install-all'.
tree-sitter/

# Recentf, history, place, etc. -- runtime state files Emacs writes here.
recentf
history
places
bookmarks
projects
treemacs-persist
treemacs-last-error-persist
dired-recent
auto-save/
/workspaces/

# Superpowers specs / plans -- local working docs, not tracked
/docs/

# Byte-compiled / native-compiled output -- generated, never tracked
*.elc
*.eln

# Emacs editing artifacts (backups, autosaves, lockfiles)
*~
*.*~
\#*\#
.\#*

# Misc package crumbs
*.cache*
*.log
*.eld
.dap-breakpoints
.emacs.desktop
.emacs.desktop.lock
.org-id-locations
.projectile
.tern-port
.yas-compiled-snippets.el
flycheck_*.el
org-roam.db
forge-database.sqlite
forge-database.sqlite-wal
forge-database.sqlite-shm
