# macOS noise
.DS_Store

# Generated package state -- but keep the versions lockfile, which pins
# every package to a specific commit and IS meant to be tracked.
straight/*
!straight/versions/
eln-cache/
var/
.cache/
auto-save-list/
elpa/
transient/
server/
eshell/
places
semanticdb
tramp
network-security.data
smex-items
ede-projects.el

# Customize output (Emacs writes here at runtime)
custom.el

# Shell-env snapshot from `scratch env' -- machine-specific paths
env

# LSP state -- workspace cache and per-machine downloaded servers.
lsp-session
lsp-servers/

# Recentf, history, place, etc. -- runtime state files Emacs writes here.
recentf
history
places
bookmarks
projects
treemacs-persist
treemacs-last-error-persist
dired-recent
auto-save/
/workspaces/

# Byte-compiled / native-compiled output -- generated, never tracked
*.elc
*.eln

# Emacs editing artifacts (backups, autosaves, lockfiles)
*~
*.*~
\#*\#
.\#*

# Misc package crumbs
*.cache*
*.log
*.eld
.dap-breakpoints
.emacs.desktop
.emacs.desktop.lock
.org-id-locations
.projectile
.tern-port
.yas-compiled-snippets.el
flycheck_*.el
org-roam.db
forge-database.sqlite
forge-database.sqlite-wal
forge-database.sqlite-shm
